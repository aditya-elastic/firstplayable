{
  "name": "firstplayable",
  "version": "0.1.1",
  "private": false,
  "description": "Platform-independent master skill and CLI for generating first playable project brains.",
  "type": "module",
  "bin": {
    "firstplayable": "dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/postinstall.mjs",
    "scripts/prepare-git.mjs",
    "skills/firstplayable/SKILL.md",
    "skills/firstplayable/agents/openai.yaml",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aditya-elastic/firstplayable.git"
  },
  "homepage": "https://github.com/aditya-elastic/firstplayable#readme",
  "bugs": {
    "url": "https://github.com/aditya-elastic/firstplayable/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "node scripts/prepare-git.mjs",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs",
    "acceptance:init": "npm run build && node --test test/firstplayable.test.mjs",
    "acceptance:skill-pack": "node test/release-audit.mjs --skill-only",
    "release:audit": "npm run build && node test/release-audit.mjs",
    "package:dry-run": "npm pack --dry-run",
    "check": "npm test && npm run release:audit && npm run package:dry-run",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "node scripts/prepublish-guard.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "esbuild": "^0.27.7"
  }
}
